<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student Portfolio Landing Page</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #f5f5f5;
      text-align: center;
    }

    header {
      background: #ffffff;
      padding: 30px 20px;
      border-bottom: 1px solid #ddd;
    }

    h1 {
      color: #1f3c88;
      margin-bottom: 10px;
    }

    .welcome-box {
      background: #eaeaea;
      padding: 30px;
      margin: 20px auto;
      width: 80%;
      border-radius: 5px;
    }

    .welcome-box h2 {
      margin: 0;
    }

    .btn {
      display: inline-block;
      margin-top: 30px;
      padding: 15px 30px;
      background: #1f3c88;
      color: white;
      text-decoration: none;
      border-radius: 30px;
      font-size: 16px;
      transition: 0.3s;
    }

    .btn:hover {
      background: #16306b;
    }

    .note {
      font-size: 12px;
      color: gray;
      margin-top: 10px;
    }

    .arrow {
      font-size: 50px;
      color: green;
      margin: 30px 0;
    }

    .preview {
      width: 80%;
      margin: auto;
    }

    iframe {
      width: 100%;
      height: 500px;
      border: 1px solid #ccc;
    }
  </style>
</head>
<body>

  <header>
    <h1>GOOD STUDENT PORTFOLIO LANDING PAGE</h1>
  </header>

  <div class="welcome-box">
    <h2>WELCOME! My Name is  Gian Claui M. Hernandez</h2>
    <p>Section/Course: BSIT1-SOUTH3</p>
  </div>

  <!-- Replace 'portfolio.pdf' with your actual PDF file -->
<a href="./Hernandez_GianClauiM_Portfolio.pdf" target="_blank" class="btn">
  VIEW MY PORTFOLIO (PDF)
</a>

  <div class="note">
    (Matches "Hernandez_GianClauiM_Portfolio.pdf" in the github)
  </div>

  <div class="arrow">↓</div>

  <div class="preview">
  <p>Click the button below to view your portfolio PDF.</p>
</div>
    <iframe src="./Hernandez_GianClauiM_Portfolio.pdf" width="100%" height="500px"></iframe>
  </div>

</body>
</html>
